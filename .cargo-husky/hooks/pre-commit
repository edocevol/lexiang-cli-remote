#!/bin/sh
#
# Pre-commit hook: format, lint, and build check
#

set -e

echo "🔍 Running pre-commit checks..."

# 1. Format check (auto-fix staged files)
echo "📝 Checking formatting..."
cargo fmt --all -- --check
if [ $? -ne 0 ]; then
    echo "❌ Formatting issues found. Run 'cargo fmt' to fix."
    exit 1
fi

# 2. Clippy lint check
echo "🔎 Running clippy..."
cargo clippy --all-targets --all-features -- -D warnings
if [ $? -ne 0 ]; then
    echo "❌ Clippy found issues. Please fix them before committing."
    exit 1
fi

# 3. Build check
echo "🔨 Checking build..."
cargo check
if [ $? -ne 0 ]; then
    echo "❌ Build failed. Please fix errors before committing."
    exit 1
fi

echo "✅ All pre-commit checks passed!"
