#!/bin/sh
#
# Pre-commit hook: format, lint, and build check
#

set -e

echo "🔍 Running pre-commit checks..."

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.rs$' || true)

# 1. Auto-format and stage changes
echo "📝 Running cargo fmt..."
cargo fmt --all
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs git add
fi

# 2. Clippy auto-fix and stage changes
echo "🔎 Running clippy --fix..."
cargo clippy --all-targets --all-features --fix --allow-dirty --allow-staged -- -D warnings
if [ -n "$STAGED_FILES" ]; then
    echo "$STAGED_FILES" | xargs git add
fi

# 3. Build check
echo "🔨 Checking build..."
cargo check
if [ $? -ne 0 ]; then
    echo "❌ Build failed. Please fix errors before committing."
    exit 1
fi

# 4. Markdown lint for tracked docs
MD_FILES=$(git ls-files -- '*.md')
if [ -n "$MD_FILES" ]; then
    if command -v npx >/dev/null 2>&1; then
        echo "📘 Running markdownlint --fix..."
        git ls-files -z -- '*.md' | xargs -0 npx --yes markdownlint-cli2 --fix
        # Stage auto-fixed markdown files
        git ls-files -z -- '*.md' | xargs -0 git add
    else
        echo "⏭️ npx not found, skipping Markdown lint."
    fi
fi

echo "✅ All pre-commit checks passed!"
